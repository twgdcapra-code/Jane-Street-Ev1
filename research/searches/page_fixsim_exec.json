    "html": "<html lang=\"en\" class=\"js .page-loader-done\"><head><link href=\"./assets/plugins/plugin-css/plugin-offcanvas.min.css\" rel=\"stylesheet\" type=\"text/css\"><link href=\"https://unpkg.com/js-offcanvas@1.2.8/dist/_css/prefixed/js-offcanvas.css\" rel=\"stylesheet\" type=\"text/css\"><link href=\"https://cdnjs.cloudflare.com/ajax/libs/highlight.js/9.12.0/styles/github.min.css\" rel=\"stylesheet\" type=\"text/css\"><link href=\"https://cdnjs.cloudflare.com/ajax/libs/highlight.js/9.12.0/styles/default.min.css\" rel=\"stylesheet\" type=\"text/css\"><link href=\"./assets/plugins/plugin-css/plugin-sticky-classes.min.css\" rel=\"stylesheet\" type=\"text/css\"><link href=\"https://cdnjs.cloudflare.com/ajax/libs/animate.css/3.5.2/animate.min.css\" rel=\"stylesheet\" type=\"text/css\">\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>FIX Execution Report (35=8) - Fields, States and Examples | FIXSIM</title>\n\n    <!-- ============================================================\n         PRECONNECT: Warm up external origins still in critical path.\n         Google Fonts + Font Awesome are now self-hosted (no preconnect\n         needed). Leadfeeder is still external — defer its handshake.\n         ============================================================ -->\n    <link rel=\"preconnect\" href=\"https://tr.lfeeder.com\" crossorigin=\"\">\n\n    <!-- Preload the LCP hero image so download starts immediately -->\n    \n\n\n    <!-- ============================================================\n         MINIMAL INLINE CSS\n         All stylesheets are render-blocking (async caused CLS).\n         This covers: (1) font-family fallback while Google Fonts\n         loads async, (2) FA check-mark fallback since Font Awesome\n         is async, (3) footer widget clearance variable.\n         ============================================================ -->\n    <style>\n        /* Font family fallback (Google Fonts loads async) */\n        body {\n            font-family: 'Open Sans',Arial,Helvetica,sans-serif\n        }\n\n        /* Brand colors (colour-orange.css + custom-style.css load async) */\n        a {\n            color: #f60\n        }\n\n        .text-primary {\n            color: #f60 !important\n        }\n\n        .btn-primary {\n            background-color: #f60;\n            border-color: #f60;\n            color: #fff\n        }\n\n            .btn-primary:hover {\n                background-color: #e55a00;\n                border-color: #e55a00\n            }\n\n        .btn-outline-primary {\n            color: #f60;\n            border-color: #f60\n        }\n\n            .btn-outline-primary:hover {\n                color: #fff;\n                background-color: #f60\n            }\n\n        .nav-link.orangy {\n            color: #f60;\n            font-weight: 700\n        }\n\n        /* Bootstrap text utilities (bootstrap.min.css loads async — define the critical ones here) */\n        .text-white { color: #fff !important }\n        .text-muted { color: #6c757d !important }\n        .text-center { text-align: center !important }\n        .text-uppercase { text-transform: uppercase !important }\n        .font-weight-bold { font-weight: 700 !important }\n        .font-weight-normal { font-weight: 400 !important }\n        .lead { font-size: 1.25rem; font-weight: 300 }\n\n        /* FA checkmark fallback (Font Awesome loads async) */\n        .fa-check {\n            font-style: normal\n        }\n\n            .fa-check::before {\n                content: \"\\2713\";\n                color: #f60;\n                margin-right: .5rem\n            }\n\n        /* Footer widget clearance */\n        @media (min-width: 768px) {\n            body {\n                --fixsim-footer-safe-bottom: 90px\n            }\n        }\n    </style>\n\n    <!-- ============================================================\n         CSS LOADING STRATEGY\n         Bootstrap is split into:\n           - bootstrap-critical.min.css (~76 KB): reboot, type, grid,\n             buttons, nav, navbar, card, common utilities. Blocking,\n             because these define above-the-fold geometry — anything\n             missing here causes CLS when the async file lands.\n           - bootstrap.min.css (~152 KB): full bundle loaded async\n             for modals, dropdowns, alerts, forms, tables, etc.\n             (rules already in critical get harmlessly re-applied)\n         Theme CSS stays blocking — has layout-affecting navbar/\n         positioning rules that caused CLS when loaded async.\n         ============================================================ -->\n    <link href=\"/Content/css?v=nZpRsA55L8Hv1WygcuhCwSZ9m4bHbXHh2dfAlub45Kg1\" rel=\"stylesheet\">\n\n    <!-- Blocking: critical bootstrap subset (prevents CLS) -->\n    <link rel=\"stylesheet\" href=\"/Content/bootstrap-critical.min.css\">\n    <!-- Async: full bootstrap for below-the-fold components -->\n    <link rel=\"stylesheet\" href=\"/Content/bootstrap.min.css\" as=\"style\" onload=\"this.onload=null;this.rel='stylesheet'\">\n    <noscript><link rel=\"stylesheet\" href=\"/Content/bootstrap.min.css\"></noscript>\n    <link href=\"/assets/css/theme-style.min.css\" rel=\"stylesheet\">\n\n\n    <!-- Self-hosted Font Awesome (was cdnjs) — async to prevent render blocking -->\n    <link rel=\"stylesheet\" href=\"/assets/fontawesome/css/all.min.css\" as=\"style\" onload=\"this.onload=null;this.rel='stylesheet'\">\n    <link rel=\"stylesheet\" href=\"/assets/fontawesome/css/v4-shims.min.css\" as=\"style\" onload=\"this.onload=null;this.rel='stylesheet'\">\n\n    <link rel=\"stylesheet\" href=\"/assets/plugins/flag-icon-css/css/flag-icon.min.css\" as=\"style\" onload=\"this.onload=null;this.rel='stylesheet'\">\n\n\n    <noscript>\n        <link rel=\"stylesheet\" href=\"/assets/fontawesome/css/all.min.css\">\n        <link rel=\"stylesheet\" href=\"/assets/fontawesome/css/v4-shims.min.css\">\n        <link rel=\"stylesheet\" href=\"/assets/plugins/flag-icon-css/css/flag-icon.min.css\">\n    </noscript>\n\n    <!-- Favicons -->\n    <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/assets/favicons/apple-touch-icon.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"/assets/favicons/favicon-32x32.png\">\n    <link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"/assets/favicons/favicon-16x16.png\">\n    <link rel=\"shortcut icon\" href=\"/assets/favicons/favicon.ico\">\n    <meta name=\"msapplication-config\" content=\"/assets/favicons/browserconfig.xml\">\n    <meta name=\"theme-color\" content=\"#ffffff\">\n\n    <!-- Self-hosted Google Fonts (was fonts.googleapis.com + fonts.gstatic.com).\n         Latin subset only; woff2 files live under /assets/fonts/google/.\n         font-display:swap preserved so paint isn't blocked on font load.\n         Preload the body-font woff2 so Open Sans 400 starts downloading\n         in parallel with the CSS rather than after it parses. -->\n    <link rel=\"preload\" href=\"/assets/fonts/google/memvYaGs126MiZpBA-UvWbX2vVnXBbObj2OVTS-muw.woff2\" as=\"font\" type=\"font/woff2\" crossorigin=\"\">\n    <link rel=\"stylesheet\" href=\"/assets/css/google-fonts.css\" as=\"style\" onload=\"this.onload=null;this.rel='stylesheet'\">\n    <noscript><link rel=\"stylesheet\" href=\"/assets/css/google-fonts.css\"></noscript>\n\n    <!-- jQuery / Popper / Bootstrap JS (self-hosted, deferred) -->\n    <script async=\"\" src=\"https://snap.licdn.com/li.lms-analytics/insight.old.min.js\"></script><script src=\"https://sc.lfeeder.com/lftracker_v1_lAxoEaKE33W7OYGd.js\" async=\"\"></script><script type=\"text/javascript\" async=\"\" src=\"https://snap.licdn.com/li.lms-analytics/insight.min.js\"></script><script src=\"/Scripts/jquery-3.3.1.min.js\" defer=\"\"></script>\n    <script src=\"/Scripts/popper.min.js\" defer=\"\"></script>\n    <script src=\"/Scripts/bootstrap.min.js\" defer=\"\"></script><script src=\"./assets/plugins/bootstrap-hover-dropdown/bootstrap-hover-dropdown.min.js\"></script>\n    <script src=\"/assets/js/custom-script.js\" defer=\"\"></script>\n    <script src=\"/assets/js/script.min.js\" defer=\"\"></script>\n\n    \n    <meta name=\"description\" content=\"The FIX Execution Report (35=8) explained - ExecType vs OrdStatus, order lifecycle states, common mistakes, and real message examples you can paste into a parser.\">\n\n\n\n    <link rel=\"canonical\" href=\"https://www.fixsim.com/fix-execution-report\">\n\n\n\n\n    <!-- Global Schema: SoftwareApplication + Organization (sitewide) -->\n    <script type=\"application/ld+json\">\n        {\n          \"@context\": \"https://schema.org\",\n          \"@type\": \"SoftwareApplication\",\n          \"name\": \"FIXSIM\",\n          \"url\": \"https://www.fixsim.com\",\n          \"applicationCategory\": \"FinanceApplication\",\n          \"applicationSubCategory\": \"FIX Protocol Testing Software\",\n          \"operatingSystem\": \"Web (browser-based, no installation required)\",\n          \"description\": \"FIXSIM is a web-based FIX protocol simulator and testing platform used by broker-dealers, OMS/EMS vendors, buy-side firms, exchanges, and fintech teams to validate FIX connectivity, order routing, and execution handling. Supports FIX 4.0 through FIX 5.0SP2, manual testing via blotter and message views, and automated regression testing via Rule Builder and REST API.\",\n          \"featureList\": [\n            \"FIX protocol simulation (FIX 4.0 – FIX 5.0SP2)\",\n            \"Session layer testing: sequencing, resends, duplicates, recovery\",\n            \"Application layer testing: business logic and exception paths\",\n            \"Manual testing via blotter and message views\",\n            \"Automated regression testing via Rule Builder\",\n            \"REST API for CI/CD and scripted workflows\",\n            \"OMS and EMS integration testing\",\n            \"High-volume stress testing\",\n            \"Multi-user support\",\n            \"99.9% uptime SLA\",\n            \"Browser-based — no downloads or installs required\"\n          ],\n          \"offers\": {\n            \"@type\": \"Offer\",\n            \"price\": \"0\",\n            \"priceCurrency\": \"USD\",\n            \"description\": \"7-day free trial, no credit card required. Paid plans available on monthly subscription with no annual contracts.\",\n            \"availability\": \"https://schema.org/InStock\",\n            \"url\": \"https://www.fixsim.com/pricing\"\n          },\n          \"publisher\": {\n            \"@type\": \"Organization\",\n            \"name\": \"Gamma Three Trading, LLC\",\n            \"url\": \"https://www.gammathreetrading.com\"\n          },\n          \"datePublished\": \"2012-01-01\",\n          \"softwareHelp\": {\n            \"@type\": \"CreativeWork\",\n            \"url\": \"https://www.fixsim.com/userguide\"\n          }\n        }\n    </script>\n    <script type=\"application/ld+json\">\n        {\n          \"@context\": \"https://schema.org\",\n          \"@type\": \"Organization\",\n          \"name\": \"FIXSIM\",\n          \"legalName\": \"Gamma Three Trading, LLC\",\n          \"url\": \"https://www.fixsim.com\",\n          \"logo\": \"https://www.fixsim.com/assets/favicons/apple-touch-icon.png\",\n          \"description\": \"FIXSIM, a product of Gamma Three Trading, LLC, provides web-based FIX protocol simulation and testing tools for trading firms, broker-dealers, OMS/EMS vendors, and fintech teams. In production since 2012.\",\n          \"foundingDate\": \"2012\",\n          \"contactPoint\": [\n            {\n              \"@type\": \"ContactPoint\",\n              \"url\": \"https://www.fixsim.com/contact\",\n              \"contactType\": \"customer support\",\n              \"availableLanguage\": \"English\"\n            },\n            {\n              \"@type\": \"ContactPoint\",\n              \"url\": \"https://www.fixsim.com/trial\",\n              \"contactType\": \"sales\",\n              \"availableLanguage\": \"English\"\n            }\n          ]\n        }\n    </script>\n\n    \n    \n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"FAQPage\",\n  \"mainEntity\": [\n    {\n      \"@type\": \"Question\",\n      \"name\": \"What is a FIX Execution Report?\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"A FIX Execution Report (MsgType 35=8) is the broker's response to any order action. It covers acknowledgements, partial fills, full fills, cancel confirmations, and rejections. Every state change in an order's lifecycle generates an Execution Report.\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"What is the difference between ExecType and OrdStatus in FIX?\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"ExecType (tag 150) describes what just happened in this specific report. OrdStatus (tag 39) describes the current state of the order. For example, a partial fill has ExecType=F (Trade) and OrdStatus=1 (PartiallyFilled). They move together but are not the same field.\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"What is LeavesQty in a FIX Execution Report?\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"LeavesQty (tag 151) is the quantity still open after this execution. On a partial fill of 200 out of 500 shares, LeavesQty would be 300. When an order is fully filled or canceled, LeavesQty is 0.\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"Why does a FIX Execution Report have both ClOrdID and OrderID?\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"ClOrdID (tag 11) is your identifier for the order, assigned by your system. OrderID (tag 37) is the broker's identifier for the same order. Both travel in every Execution Report. When referencing an order in a cancel or replace, you use your ClOrdID. The broker uses their OrderID internally.\"\n      }\n    }\n  ]\n}\n</script>\n\n\n</head>\n\n<body class=\"page navbar-layout-default\"><div class=\"c-offcanvas-content-wrap\">\n\n    <!-- Google Tag Manager (noscript) -->\n    <noscript>\n        <iframe src=\"https://www.googletagmanager.com/ns.html?id=GTM-NV94CMX2\"\n                height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\n    </noscript>\n    <!-- End Google Tag Manager (noscript) -->\n\n    <div id=\"header\">\n        <div class=\"header-upper\">\n            <div class=\"header-inner container \">\n                <div class=\"header-block-flex order-12 mr-auto\">\n                    <nav class=\"nav nav-sm header-block-flex\"></nav>\n                </div>\n\n                <div class=\"nav header-block-flex order-12\">\n                    <a class=\"nav-link text-xs text-uppercase d-none d-md-block\" href=\"https://portal.fixsim.com\">Sign In</a>\n                </div>\n            </div>\n        </div>\n\n        <div style=\"visibility: hidden; display: none;\"></div><div data-toggle=\"sticky\" class=\"sticky\" style=\"top: 0px;\"><div class=\"sticky-inner\">\n            <div class=\"header\">\n                <div class=\"header-inner container\">\n\n                    <div class=\"header-block order-12\">\n                        <a href=\"#top\" class=\"btn btn-link btn-icon header-btn float-right d-lg-none js-offcanvas-trigger js-offcanvas-trigger-1783870705047 c-button\" data-toggle=\"off-canvas\" data-target=\".navbar-main\" data-settings=\"{&quot;cloneTarget&quot;:true, &quot;targetClassExtras&quot;: &quot;navbar-offcanvas&quot;}\" role=\"button\" aria-controls=\"js-offcanvas-target-1783870705047-clone\" aria-expanded=\"false\"><span class=\"c-button__text\">\n                            <i class=\"fa fa-bars\"></i>\n                        </span></a>\n                    </div>\n\n                    <div class=\"navbar navbar-expand-md navbar-static-top\">\n                        <a class=\"navbar-brand\" href=\"/\">\n                            <img src=\"/assets/favicons/apple-touch-icon.png\" width=\"30\" height=\"30\" class=\"d-inline-block align-top\" alt=\"FIX Simulator for FIX Protocol Testing\">\n                            FIXSIM\n                        </a>\n\n                        <div class=\"navbar-main collapse\">\n                            <ul class=\"nav navbar-nav navbar-nav-stretch float-lg-right dropdown-effect-fade\">\n                                <li class=\"nav-item\">\n                                    <a class=\"nav-link\" href=\"/\">Home</a>\n                                </li>\n\n                                <li class=\"nav-item\">\n                                    <a class=\"nav-link\" href=\"/pricing\">Pricing</a>\n                                </li>\n\n                                <li class=\"nav-item dropdown\">\n                                    <a href=\"#\" class=\"nav-link dropdown-toggle\" id=\"pages-drop\" data-toggle=\"dropdown\" data-hover=\"dropdown\">More Info</a>\n                                    <div class=\"dropdown-menu\">\n                                        <a class=\"dropdown-item font-weight-bold text-primary\" href=\"/oms-ems-fix-testing\">FIX Testing for OMS/EMS</a>\n                                        <a class=\"dropdown-item font-weight-bold text-primary\" href=\"/compare-fix-testing-tools\">Compare Tools</a>\n                                        <div class=\"dropdown-divider\"></div>\n\n                                        <a class=\"dropdown-item\" href=\"/fix-simulator\">FIX Simulator</a>\n                                        <a class=\"dropdown-item\" href=\"/fix-protocol-testing\">FIX Testing</a>\n                                        <a class=\"dropdown-item\" href=\"/fix-protocol-tutorial\">FIX Tutorial</a>\n                                        <a class=\"dropdown-item\" href=\"/fix-parser\">FIX Parser</a>\n                                        <a class=\"dropdown-item\" href=\"/sample-fix-messages\">Sample FIX Messages</a>\n                                        <a class=\"dropdown-item\" href=\"/fix-simulation-demo\">Demo</a>\n                                        <a class=\"dropdown-item\" href=\"/faq\">FAQ</a>\n                                        <a class=\"dropdown-item\" href=\"/resources\">Resources</a>\n                                    </div>\n                                </li>\n\n                                <li class=\"nav-item\">\n                                    <a class=\"nav-link\" href=\"/about\">About Us</a>\n                                </li>\n\n                                <li class=\"nav-item\">\n                                    <a class=\"nav-link\" href=\"/userguide\">User Guide</a>\n                                </li>\n\n                                <li class=\"nav-item\">\n                                    <a class=\"nav-link\" href=\"/contact\">Contact Us</a>\n                                </li>\n\n                                <li class=\"nav-item\">\n                                    <a class=\"nav-link orangy\" href=\"https://portal.fixsim.com\">Sign In</a>\n                                </li>\n                            </ul>\n                        </div>\n                    </div>\n\n                </div>\n            </div>\n        </div></div>\n    </div>\n\n    \n\n    <div id=\"content\">\n        <div class=\"container min-vh-100\">\n            \n\n\n\n\n<div class=\"row\">\n    <div class=\"col-lg-8\">\n\n        <h1>FIX Execution Report (35=8)</h1>\n\n        <p>\n            The Execution Report is the broker's response to everything. Send a New Order Single and you get one back.\n            Cancel an order and you get one back. Partial fill, full fill, reject -- all Execution Reports.\n            It's the most important message type in FIX and also the one with the most implementation traps.\n        </p>\n\n        <hr class=\"my-4\">\n\n        <h2>ExecType vs OrdStatus</h2>\n\n        <p>\n            This is where most implementations go wrong. The two fields are related but different:\n        </p>\n        <ul>\n            <li><strong>ExecType (tag 150)</strong> -- what just happened in this report</li>\n            <li><strong>OrdStatus (tag 39)</strong> -- the current state of the order</li>\n        </ul>\n        <p>\n            On an order acknowledgement, ExecType=0 (New) and OrdStatus=0 (New). Both say the same thing.\n            On a partial fill, ExecType=F (Trade) and OrdStatus=1 (PartiallyFilled). Now they diverge.\n            ExecType tells you a trade happened. OrdStatus tells you the order still has quantity open.\n        </p>\n        <p>\n            A common mistake is treating them as the same field or only checking one of them.\n            Brokers can and do send combinations that seem redundant until an edge case hits.\n        </p>\n\n        <table class=\"table table-bordered table-striped mt-3 mb-4\">\n            <thead class=\"thead-dark\">\n                <tr>\n                    <th>Scenario</th>\n                    <th>ExecType (150)</th>\n                    <th>OrdStatus (39)</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr>\n                    <td>Order acknowledged</td>\n                    <td>0 = New</td>\n                    <td>0 = New</td>\n                </tr>\n                <tr>\n                    <td>Partial fill</td>\n                    <td>F = Trade</td>\n                    <td>1 = PartiallyFilled</td>\n                </tr>\n                <tr>\n                    <td>Full fill</td>\n                    <td>F = Trade</td>\n                    <td>2 = Filled</td>\n                </tr>\n                <tr>\n                    <td>Cancel confirmed</td>\n                    <td>4 = Canceled</td>\n                    <td>4 = Canceled</td>\n                </tr>\n                <tr>\n                    <td>Replace confirmed</td>\n                    <td>5 = Replace</td>\n                    <td>0 = New (resets)</td>\n                </tr>\n                <tr>\n                    <td>Order rejected</td>\n                    <td>8 = Rejected</td>\n                    <td>8 = Rejected</td>\n                </tr>\n                <tr>\n                    <td>Pending cancel</td>\n                    <td>6 = PendingCancel</td>\n                    <td>6 = PendingCancel</td>\n                </tr>\n            </tbody>\n        </table>\n\n        <hr class=\"my-4\">\n\n        <h2>Key Fields</h2>\n\n        <table class=\"table table-bordered table-striped mt-3 mb-4\">\n            <thead class=\"thead-dark\">\n                <tr>\n                    <th style=\"width: 80px;\">Tag</th>\n                    <th style=\"width: 160px;\">Field</th>\n                    <th>Notes</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr>\n                    <td><strong>11</strong></td>\n                    <td>ClOrdID</td>\n                    <td>Your order identifier. Echoed back in every report for that order.</td>\n                </tr>\n                <tr>\n                    <td><strong>14</strong></td>\n                    <td>CumQty</td>\n                    <td>Total quantity filled so far, cumulative across all fills.</td>\n                </tr>\n                <tr>\n                    <td><strong>17</strong></td>\n                    <td>ExecID</td>\n                    <td>Unique identifier for this specific report. Increments with every report sent.</td>\n                </tr>\n                <tr>\n                    <td><strong>31</strong></td>\n                    <td>LastPx</td>\n                    <td>Price of this fill. Only present on trade reports (ExecType=F).</td>\n                </tr>\n                <tr>\n                    <td><strong>32</strong></td>\n                    <td>LastQty</td>\n                    <td>Quantity of this fill. Only present on trade reports.</td>\n                </tr>\n                <tr>\n                    <td><strong>37</strong></td>\n                    <td>OrderID</td>\n                    <td>The broker's identifier for the order. Different from your ClOrdID.</td>\n                </tr>\n                <tr>\n                    <td><strong>38</strong></td>\n                    <td>OrderQty</td>\n                    <td>Original order quantity as submitted.</td>\n                </tr>\n                <tr>\n                    <td><strong>39</strong></td>\n                    <td>OrdStatus</td>\n                    <td>Current state of the order. See ExecType vs OrdStatus above.</td>\n                </tr>\n                <tr>\n                    <td><strong>58</strong></td>\n                    <td>Text</td>\n                    <td>Free text reason, usually populated on rejects.</td>\n                </tr>\n                <tr>\n                    <td><strong>150</strong></td>\n                    <td>ExecType</td>\n                    <td>What happened in this specific report.</td>\n                </tr>\n                <tr>\n                    <td><strong>151</strong></td>\n                    <td>LeavesQty</td>\n                    <td>Quantity still open. Zero when filled or canceled.</td>\n                </tr>\n            </tbody>\n        </table>\n\n        <hr class=\"my-4\">\n\n        <h2>Example Messages</h2>\n        <p>Paste any of these into the <a href=\"/fix-parser\">FIX parser</a> to see every tag decoded.</p>\n\n        <h3 style=\"font-size: 1.05rem; margin-top: 1.5rem;\">Acknowledgement</h3>\n        <code style=\"display: block; background: #f8f9fa; padding: 10px; border-radius: 4px; font-size: 0.82rem; word-break: break-all;\">\n            8=FIX.4.4|9=160|35=8|34=2|49=BROKER|52=20240115-14:30:02.000|56=OMS|11=ORD-001|14=0|17=EXEC-001|20=0|37=BRKR-001|38=500|39=0|40=2|44=150.25|54=1|55=AAPL|150=0|151=500|10=088|\n        </code>\n\n        <h3 style=\"font-size: 1.05rem; margin-top: 1.5rem;\">Partial Fill</h3>\n        <code style=\"display: block; background: #f8f9fa; padding: 10px; border-radius: 4px; font-size: 0.82rem; word-break: break-all;\">\n            8=FIX.4.4|9=180|35=8|34=3|49=BROKER|52=20240115-14:30:05.000|56=OMS|6=150.25|11=ORD-001|14=200|17=EXEC-002|20=0|31=150.25|32=200|37=BRKR-001|38=500|39=1|40=2|44=150.25|54=1|55=AAPL|150=F|151=300|10=112|\n        </code>\n\n        <h3 style=\"font-size: 1.05rem; margin-top: 1.5rem;\">Full Fill</h3>\n        <code style=\"display: block; background: #f8f9fa; padding: 10px; border-radius: 4px; font-size: 0.82rem; word-break: break-all;\">\n            8=FIX.4.4|9=180|35=8|34=4|49=BROKER|52=20240115-14:30:08.000|56=OMS|6=150.25|11=ORD-001|14=500|17=EXEC-003|20=0|31=150.25|32=300|37=BRKR-001|38=500|39=2|40=2|44=150.25|54=1|55=AAPL|150=F|151=0|10=199|\n        </code>\n\n        <h3 style=\"font-size: 1.05rem; margin-top: 1.5rem;\">Cancel Confirmed</h3>\n        <code style=\"display: block; background: #f8f9fa; padding: 10px; border-radius: 4px; font-size: 0.82rem; word-break: break-all;\">\n            8=FIX.4.4|9=165|35=8|34=5|49=BROKER|52=20240115-14:31:01.000|56=OMS|11=ORD-002|14=0|17=EXEC-004|20=0|37=BRKR-001|38=500|39=4|40=2|41=ORD-001|44=150.25|54=1|55=AAPL|150=4|151=0|10=077|\n        </code>\n\n        <h3 style=\"font-size: 1.05rem; margin-top: 1.5rem;\">Reject</h3>\n        <code style=\"display: block; background: #f8f9fa; padding: 10px; border-radius: 4px; font-size: 0.82rem; word-break: break-all;\">\n            8=FIX.4.4|9=170|35=8|34=6|49=BROKER|52=20240115-14:30:03.000|56=OMS|11=ORD-001|14=0|17=EXEC-005|20=0|37=NONE|38=500|39=8|40=2|44=150.25|54=1|55=AAPL|58=Unknown symbol|150=8|151=0|10=143|\n        </code>\n\n        <hr class=\"my-4\">\n\n        <h2>Common Implementation Mistakes</h2>\n\n        <h3 style=\"font-size: 1.05rem; margin-top: 1.5rem;\">Only checking OrdStatus</h3>\n        <p>\n            Some implementations ignore ExecType and only look at OrdStatus to determine what happened.\n            This breaks on pending states and on brokers that send intermediary reports before the final state.\n            Always check both.\n        </p>\n\n        <h3 style=\"font-size: 1.05rem; margin-top: 1.5rem;\">Not handling Pending states</h3>\n        <p>\n            PendingCancel (39=6) and PendingNew (39=A) are real states that some brokers send.\n            If your system expects a cancel confirmation and gets a PendingCancel first,\n            it needs to wait for the final Canceled report rather than treating the pending as a failure.\n        </p>\n\n        <h3 style=\"font-size: 1.05rem; margin-top: 1.5rem;\">CumQty + LeavesQty math</h3>\n        <p>\n            CumQty + LeavesQty should always equal OrderQty. If it doesn't, something is wrong.\n            This is a quick sanity check worth adding to your processing logic.\n        </p>\n\n        <h3 style=\"font-size: 1.05rem; margin-top: 1.5rem;\">Assuming ExecID is sequential</h3>\n        <p>\n            ExecID (tag 17) is unique but not guaranteed to be sequential across sessions or reconnects.\n            Don't use it as a counter. Use it as a unique key for deduplication.\n        </p>\n\n        <hr class=\"my-4\">\n\n        <div class=\"mt-4 mb-5\" style=\"background: linear-gradient(135deg, #1a2f4e 0%, #2a4a7f 100%); border-radius: 8px; padding: 24px 32px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;\">\n            <div>\n                <h4 style=\"color: #ffffff; margin: 0 0 6px 0; font-size: 1.2rem;\">Test your Execution Report handling</h4>\n                <p style=\"color: #b0c4de; margin: 0; font-size: 0.95rem;\">FIXSIM lets you trigger any ExecType and OrdStatus combination on demand. No credit card required.</p>\n            </div>\n            <a href=\"/trial\" style=\"background-color: #f47b20; color: #ffffff; padding: 12px 28px; border-radius: 5px; text-decoration: none; font-weight: 600; white-space: nowrap; font-size: 0.95rem;\">\n                Start Free Trial →\n            </a>\n        </div>\n\n    </div>\n\n    <div class=\"col-lg-4 d-none d-lg-block\">\n        <div style=\"position: sticky; top: 20px; background: #f8f9fa; border-radius: 6px; padding: 20px; border-left: 3px solid #f47b20;\">\n            <h5 style=\"margin-top: 0;\">On this page</h5>\n            <ul style=\"list-style: none; padding: 0; margin: 0;\">\n                <li style=\"padding: 4px 0;\"><a href=\"#\" onclick=\"document.querySelectorAll('h2')[0].scrollIntoView(); return false;\">ExecType vs OrdStatus</a></li>\n                <li style=\"padding: 4px 0;\"><a href=\"#\" onclick=\"document.querySelectorAll('h2')[1].scrollIntoView(); return false;\">Key Fields</a></li>\n                <li style=\"padding: 4px 0;\"><a href=\"#\" onclick=\"document.querySelectorAll('h2')[2].scrollIntoView(); return false;\">Example Messages</a></li>\n                <li style=\"padding: 4px 0;\"><a href=\"#\" onclick=\"document.querySelectorAll('h2')[3].scrollIntoView(); return false;\">Common Mistakes</a></li>\n            </ul>\n        </div>\n    </div>\n\n</div>\n\n        </div>\n    </div>\n\n    <hr>\n\n    <!-- ======== Region: #content-below ======== -->\n    <div id=\"content-below\">\n        <div class=\"bg-primary bg-op-9 text-white py-4\">\n            <div class=\"container\">\n                <div class=\"row text-center text-lg-left align-items-lg-center\">\n                    <div class=\"col-12 col-lg-7 text-white\">\n                        <!-- Updated to broaden keyword coverage + improve clarity -->\n                        <h2 class=\"font-weight-bold 